# === Sybase IQ Agent ===
# URL base do agent HTTP (atualizar quando o Cloudflare Tunnel reiniciar)
AGENT_URL=https://featured-logistics-advertisement-beats.trycloudflare.com

# Chave de autenticação do agent
AGENT_API_KEY=chave123abc456def789

# === Auth ===
# Segredo JWT — use uma string longa e aleatória em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_uma_string_secreta_longa

# === Banco SQLite (auth local) ===
# Local:    ./data/prefeitura.db  (padrão)
# Railway:  /data/prefeitura.db   (com Volume montado em /data)
DATABASE_PATH=./data/prefeitura.db
